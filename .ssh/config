Host salish
	HostName salish.pgc.nrcan.gc.ca
	User dravel
	IdentityFile ~/.ssh/id_ed25519
	IdentitiesOnly yes


Host leo2g
	HostName leo2g.pgc.nrcan.gc.ca
	User draval
	ProxyJump salish
	IdentityFile ~/.ssh/id_ed25519
	
# Personal Github
Host github-personal
	HostName github.com
	User git
	IdentityFile ~/.ssh/id_github
	IdentitiesOnly yes

# Work Github

Host github-work
	HostName github.com
	User git
	IdentityFile ~/.ssh/id_github_work